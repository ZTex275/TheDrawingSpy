<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DrawingSpy.Pages.OutcomePage"
             Title="Итог раунда"
             BackgroundColor="#1B1340"
             NavigationPage.HasBackButton="False">

    <Grid>
        <ScrollView>
            <VerticalStackLayout Padding="24" Spacing="18" VerticalOptions="Center">

                <Label x:Name="HeaderLabel"
                       Text="Чем закончился раунд?"
                       FontSize="26"
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalTextAlignment="Center"
                       HorizontalOptions="Center" />

                <Label Text="Обсудите и выберите исход. Баллы начислятся автоматически."
                       FontSize="15"
                       TextColor="#C7BFEA"
                       HorizontalTextAlignment="Center"
                       HorizontalOptions="Center"
                       Margin="0,0,0,10" />

                <Button Text="✅  Шпиона нашли"
                        Clicked="OnSpyFound"
                        BackgroundColor="#2E9E5B"
                        TextColor="White"
                        FontSize="18"
                        FontAttributes="Bold"
                        HeightRequest="64"
                        CornerRadius="14" />
                <Label Text="Все, кроме шпиона, получают по 1 баллу"
                       FontSize="13" TextColor="#9FE3BA" HorizontalOptions="Center" Margin="0,-8,0,4" />

                <Button Text="❌  Шпиона определили неверно"
                        Clicked="OnSpyNotFound"
                        BackgroundColor="#C9A227"
                        TextColor="White"
                        FontSize="18"
                        FontAttributes="Bold"
                        HeightRequest="64"
                        CornerRadius="14" />
                <Label Text="Шпион получает 1 балл"
                       FontSize="13" TextColor="#F0DDA0" HorizontalOptions="Center" Margin="0,-8,0,4" />

                <Button Text="🕵️  Шпион отгадал слово"
                        Clicked="OnSpyGuessed"
                        BackgroundColor="#C0392B"
                        TextColor="White"
                        FontSize="18"
                        FontAttributes="Bold"
                        HeightRequest="64"
                        CornerRadius="14" />
                <Label Text="Шпион получает 2 балла"
                       FontSize="13" TextColor="#F0A9A0" HorizontalOptions="Center" Margin="0,-8,0,4" />

            </VerticalStackLayout>
        </ScrollView>

        <Grid x:Name="RevealOverlay"
              IsVisible="False"
              BackgroundColor="#CC000000"
              Padding="24">
            <Border Stroke="#5A4A9A"
                    StrokeThickness="1"
                    BackgroundColor="#251A52"
                    Padding="0"
                    MaximumWidthRequest="340"
                    VerticalOptions="Center"
                    HorizontalOptions="Center"
                    StrokeShape="RoundRectangle 20">
                <VerticalStackLayout Spacing="0">

                    <Label Text="Раскрытие раунда"
                           FontSize="17"
                           FontAttributes="Bold"
                           TextColor="White"
                           HorizontalTextAlignment="Center"
                           Padding="20,18,20,14" />

                    <BoxView HeightRequest="1" Color="#3A2D6E" />

                    <VerticalStackLayout Padding="16,14" Spacing="10">

                        <Border BackgroundColor="#3A0E1E"
                                Stroke="#5A2840"
                                StrokeThickness="1"
                                Padding="14,12"
                                StrokeShape="RoundRectangle 14">
                            <Grid ColumnDefinitions="42,*" RowDefinitions="Auto,Auto" ColumnSpacing="12">
                                <Label Grid.Row="0" Grid.RowSpan="2" Grid.Column="0"
                                       Text="🕵️"
                                       FontSize="26"
                                       VerticalOptions="Center"
                                       HorizontalOptions="Center" />
                                <Label Grid.Row="0" Grid.Column="1"
                                       Text="ШПИОН"
                                       FontSize="11"
                                       FontAttributes="Bold"
                                       TextColor="#FF8A8A"
                                       CharacterSpacing="1" />
                                <Label Grid.Row="1" Grid.Column="1"
                                       x:Name="SpyNameLabel"
                                       Text=""
                                       FontSize="22"
                                       FontAttributes="Bold"
                                       TextColor="White"
                                       LineBreakMode="WordWrap" />
                            </Grid>
                        </Border>

                        <Border BackgroundColor="#152B1B"
                                Stroke="#2A5A3A"
                                StrokeThickness="1"
                                Padding="14,12"
                                StrokeShape="RoundRectangle 14">
                            <Grid ColumnDefinitions="42,*" RowDefinitions="Auto,Auto" ColumnSpacing="12">
                                <Label Grid.Row="0" Grid.RowSpan="2" Grid.Column="0"
                                       Text="📖"
                                       FontSize="26"
                                       VerticalOptions="Center"
                                       HorizontalOptions="Center" />
                                <Label Grid.Row="0" Grid.Column="1"
                                       Text="СЛОВО"
                                       FontSize="11"
                                       FontAttributes="Bold"
                                       TextColor="#9FE3BA"
                                       CharacterSpacing="1" />
                                <Label Grid.Row="1" Grid.Column="1"
                                       x:Name="WordRevealLabel"
                                       Text=""
                                       FontSize="22"
                                       FontAttributes="Bold"
                                       TextColor="#B9A4FF"
                                       LineBreakMode="WordWrap" />
                            </Grid>
                        </Border>

                    </VerticalStackLayout>

                    <BoxView HeightRequest="1" Color="#3A2D6E" />

                    <Button Text="К таблице баллов"
                            Clicked="OnRevealContinue"
                            BackgroundColor="#7C4DFF"
                            TextColor="White"
                            FontSize="16"
                            FontAttributes="Bold"
                            HeightRequest="50"
                            CornerRadius="0"
                            Margin="0" />
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
