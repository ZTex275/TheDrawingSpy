<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DrawingSpy.Pages.RevealPage"
             Title="Раздача"
             BackgroundColor="#1B1340"
             NavigationPage.HasBackButton="False">

    <Grid x:Name="RootGrid" Padding="24" RowDefinitions="*,Auto">

        <VerticalStackLayout Grid.Row="0" Spacing="18" VerticalOptions="Center" HorizontalOptions="Fill">

            <Label x:Name="StepLabel"
                   Text=""
                   FontSize="16"
                   TextColor="#C7BFEA"
                   HorizontalOptions="Center" />

            <Label x:Name="TitleLabel"
                   Text=""
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalTextAlignment="Center"
                   HorizontalOptions="Center" />

            <Border x:Name="WordBorder"
                    IsVisible="False"
                    Stroke="#3A2D6E" StrokeThickness="1"
                    BackgroundColor="#251A52"
                    Padding="24" Margin="0,10"
                    StrokeShape="RoundRectangle 20">
                <Label x:Name="WordLabel"
                       Text=""
                       FontSize="40"
                       FontAttributes="Bold"
                       TextColor="#B9A4FF"
                       HorizontalTextAlignment="Center"
                       HorizontalOptions="Center" />
            </Border>

            <Label x:Name="HintLabel"
                   Text=""
                   FontSize="15"
                   TextColor="#8C80BE"
                   HorizontalTextAlignment="Center"
                   HorizontalOptions="Center"
                   Margin="0,12,0,0" />
        </VerticalStackLayout>

        <Button x:Name="ActionButton"
                Grid.Row="1"
                Text="Показать слово"
                Clicked="OnActionClicked"
                IsEnabled="False"
                BackgroundColor="#7C4DFF"
                TextColor="White"
                FontSize="17"
                FontAttributes="Bold"
                HeightRequest="56"
                CornerRadius="14"
                Margin="0,16,0,10" />
    </Grid>
</ContentPage>
