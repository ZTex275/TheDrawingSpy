<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DrawingSpy.Pages.SetupPage"
             Title="Рисовальный шпион"
             BackgroundColor="#1B1340">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="20">

            <Label Text="🕵️ Рисовальный шпион"
                   FontSize="26"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalOptions="Center"
                   Margin="0,10,0,0" />
                   
            <Button x:Name="ContinueButton"
                    Text="Продолжить последнюю игру"
                    Clicked="OnContinueClicked"
                    IsVisible="False"
                    BackgroundColor="#2E9E5B"
                    TextColor="White"
                    FontSize="17"
                    FontAttributes="Bold"
                    HeightRequest="52"
                    CornerRadius="14"
                    Margin="0,4,0,0" />

            <Border Stroke="#3A2D6E" StrokeThickness="1" BackgroundColor="#251A52"
                    Padding="18" StrokeShape="RoundRectangle 16">
                <VerticalStackLayout Spacing="6">
                    <Label Text="Количество игроков" TextColor="White" FontSize="16" FontAttributes="Bold" />
                    <Label Text="от 3 до 15" TextColor="#8C80BE" FontSize="12" />
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <Entry x:Name="PlayersCountEntry"
                               Text="5"
                               Keyboard="Numeric"
                               FontSize="26"
                               FontAttributes="Bold"
                               TextColor="#B9A4FF"
                               PlaceholderColor="#8C80BE"
                               MaxLength="2"
                               VerticalOptions="Center"
                               Unfocused="OnPlayersCountUnfocused"
                               Completed="OnPlayersCountCompleted"
                               TextChanged="OnPlayersCountTextChanged" />
                        <Stepper x:Name="PlayersStepper" Grid.Column="1"
                                 Minimum="3" Maximum="15" Increment="1" Value="5"
                                 ValueChanged="OnPlayersStepperChanged" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Border Stroke="#3A2D6E" StrokeThickness="1" BackgroundColor="#251A52"
                    Padding="18" StrokeShape="RoundRectangle 16">
                <VerticalStackLayout Spacing="6">
                    <Label Text="Количество раундов" TextColor="White" FontSize="16" FontAttributes="Bold" />
                    <Label Text="от 1 до 100" TextColor="#8C80BE" FontSize="12" />
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <Entry x:Name="RoundsCountEntry"
                               Text="12"
                               Keyboard="Numeric"
                               FontSize="26"
                               FontAttributes="Bold"
                               TextColor="#B9A4FF"
                               PlaceholderColor="#8C80BE"
                               MaxLength="3"
                               VerticalOptions="Center"
                               Unfocused="OnRoundsCountUnfocused"
                               Completed="OnRoundsCountCompleted" />
                        <Stepper x:Name="RoundsStepper" Grid.Column="1"
                                 Minimum="1" Maximum="100" Increment="1" Value="12"
                                 ValueChanged="OnRoundsStepperChanged" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Label Text="Имена игроков" TextColor="White" FontSize="16" FontAttributes="Bold" Margin="4,4,0,0" />

            <VerticalStackLayout x:Name="NamesContainer" Spacing="10" />

            <Button Text="Начать игру"
                    Clicked="OnStartClicked"
                    BackgroundColor="#7C4DFF"
                    TextColor="White"
                    FontSize="18"
                    FontAttributes="Bold"
                    HeightRequest="56"
                    CornerRadius="14"
                    Margin="0,10,0,30" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
