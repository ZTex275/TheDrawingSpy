<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DrawingSpy.Pages.SetupPage"
             Title="Рисовальный шпион"
             BackgroundColor="#1B1340">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="20">

            <Label Text="🕵️ Рисовальный шпион"
                   FontSize="30"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalOptions="Center"
                   Margin="0,10,0,0" />

            <Label Text="Настройте новую игру"
                   FontSize="16"
                   TextColor="#C7BFEA"
                   HorizontalOptions="Center" />

            <Border Stroke="#3A2D6E" StrokeThickness="1" BackgroundColor="#251A52"
                    Padding="18" StrokeShape="RoundRectangle 16">
                <VerticalStackLayout Spacing="6">
                    <Label Text="Количество игроков" TextColor="White" FontSize="16" FontAttributes="Bold" />
                    <Grid ColumnDefinitions="*,Auto">
                        <Label x:Name="PlayersCountLabel" Text="3"
                               FontSize="26" FontAttributes="Bold"
                               TextColor="#B9A4FF" VerticalOptions="Center" />
                        <Stepper x:Name="PlayersStepper" Grid.Column="1"
                                 Minimum="3" Maximum="12" Increment="1" Value="3"
                                 ValueChanged="OnPlayersChanged" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Border Stroke="#3A2D6E" StrokeThickness="1" BackgroundColor="#251A52"
                    Padding="18" StrokeShape="RoundRectangle 16">
                <VerticalStackLayout Spacing="6">
                    <Label Text="Количество раундов" TextColor="White" FontSize="16" FontAttributes="Bold" />
                    <Grid ColumnDefinitions="*,Auto">
                        <Label x:Name="RoundsCountLabel" Text="3"
                               FontSize="26" FontAttributes="Bold"
                               TextColor="#B9A4FF" VerticalOptions="Center" />
                        <Stepper x:Name="RoundsStepper" Grid.Column="1"
                                 Minimum="1" Maximum="30" Increment="1" Value="3"
                                 ValueChanged="OnRoundsChanged" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Label Text="Имена игроков" TextColor="White" FontSize="16" FontAttributes="Bold" Margin="4,4,0,0" />
            <Label Text="Можно оставить по умолчанию или задать свои."
                   TextColor="#C7BFEA" FontSize="13" Margin="4,-6,0,0" />

            <VerticalStackLayout x:Name="NamesContainer" Spacing="10" />

            <Button Text="Начать игру"
                    Clicked="OnStartClicked"
                    BackgroundColor="#7C4DFF"
                    TextColor="White"
                    FontSize="18"
                    FontAttributes="Bold"
                    HeightRequest="56"
                    CornerRadius="14"
                    Margin="0,10,0,30" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
