<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DrawingSpy.Controls.NewGameConfirmOverlay"
             IsVisible="False"
             HorizontalOptions="Fill"
             VerticalOptions="Fill"
             ZIndex="100">

    <Grid BackgroundColor="#CC000000" Padding="12">
        <Border Stroke="#5A4A9A"
                StrokeThickness="1"
                BackgroundColor="#251A52"
                Padding="0"
                HorizontalOptions="Fill"
                VerticalOptions="Center"
                StrokeShape="RoundRectangle 20">
            <VerticalStackLayout Spacing="0">

                <Label Text="Новая игра"
                       FontSize="17"
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalTextAlignment="Center"
                       Padding="20,18,20,14" />

                <BoxView HeightRequest="1" Color="#3A2D6E" />

                <Grid Margin="10">
                    <Label Text="Текущий прогресс будет сброшен. Настройки и имена игроков останутся на экране старта."
                           FontSize="15"
                           TextColor="#D8D2F0"
                           LineBreakMode="WordWrap" />
                </Grid>

                <BoxView HeightRequest="1" Color="#3A2D6E" />

                <Grid ColumnDefinitions="*,*" ColumnSpacing="0">
                    <Button Grid.Column="0"
                            Text="Отмена"
                            Clicked="OnCancelClicked"
                            BackgroundColor="#3A2D6E"
                            TextColor="White"
                            FontSize="16"
                            FontAttributes="Bold"
                            HeightRequest="50"
                            CornerRadius="0"
                            Margin="0" />
                    <Button Grid.Column="1"
                            Text="Новая игра"
                            Clicked="OnConfirmClicked"
                            BackgroundColor="#7C4DFF"
                            TextColor="White"
                            FontSize="16"
                            FontAttributes="Bold"
                            HeightRequest="50"
                            CornerRadius="0"
                            Margin="0" />
                </Grid>
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentView>
