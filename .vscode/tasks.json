{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "run-android",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "build",
        "-t:Run",
        "-f",
        "net10.0-android",
        "-p:AndroidSdkDirectory=${env:LOCALAPPDATA}\\Android\\Sdk",
        "-p:JavaSdkDirectory=C:\\Program Files\\Microsoft\\jdk-17.0.19.10-hotspot"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "JAVA_HOME": "C:\\Program Files\\Microsoft\\jdk-17.0.19.10-hotspot",
          "ANDROID_HOME": "${env:LOCALAPPDATA}\\Android\\Sdk",
          "ANDROID_SDK_ROOT": "${env:LOCALAPPDATA}\\Android\\Sdk"
        }
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$msCompile",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": true
      }
    }
  ]
}
